{
  "name": "asa-autobots",
  "version": "1.0.0",
  "description": "",
  "dependencies": {
    "@unitn-asa/deliveroo-js-sdk": "^1.3.10",
    "@unitn-asa/pddl-client": "^1.7.7",
    "dotenv": "^17.4.2",
    "openai": "^4.104.0",
    "punycode": "^2.3.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "whatwg-url": "^14.0.0",
    "tr46": "^4.0.0"
  },
  "private": true,
  "scripts": {
    "start": "node run_map_builder.js",
    "bdi": "node run_bdi.js",
    "llm": "node run_llm.js",
    "benchmark": "node src/benchmark/run_benchmark.js",
    "map-builder": "node run_map_builder.js",
    "test": "node --test",
    "test:coverage": "node --experimental-test-coverage --test",
    "prebuild": "node -e \"require('fs').mkdirSync('report/build',{recursive:true})\"",
    "build": "latexmk -pdf -cd -outdir=build report/report.tex",
    "postbuild": "node -e \"const fs=require('fs');fs.renameSync('report/build/report.pdf','report/report.pdf');fs.rmSync('report/build',{recursive:true,force:true})\"",
    "watch": "latexmk -pdf -pvc -cd -outdir=build report/report.tex",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('report/build',{recursive:true,force:true});fs.rmSync('report/report.pdf',{force:true})\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ale-bena/asa-autobots.git"
  },
  "keywords": [],
  "authors": [
    "Alessandro Benassi",
    "Filippo Lollato"
  ],
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ale-bena/asa-autobots/issues"
  },
  "homepage": "https://github.com/ale-bena/asa-autobots#readme"
}
