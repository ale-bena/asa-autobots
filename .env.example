# LiteLLM/OpenAI API Configuration
LITELLM_BASE_URL=https://llm.bears.disi.unitn.it/v1
LITELLM_API_KEY=your_litellm_api_key_here
LLM_MODEL=llama-3.3-70b-lmstudio

# PDDL Solver API Configuration
PAAS_HOST=http://localhost:5001

# Game Server Configuration
HOST=http://localhost:8080

# Team Agent Identities (Standard or challenge dynamic ids)
ADMIN_ID=39d92a
LLM_AGENT_ID=a0ce34
BDI_AGENT_ID=d60fa3

# JWT tokens for Agent connection authentication
TOKEN=your_bdi_agent_jwt_token_here
LLM_TOKEN=your_llm_agent_jwt_token_here

# Configurable Terminal Logging Settings (Set to 'false' to disable)
LOG_TOOL_CALLS=true
LOG_MOVEMENT=true
LOG_POLICY_UPDATES=true
LOG_MATH=true
LOG_P2P=true
LOG_PEER_STATUS=false
LOG_COLORS=true
